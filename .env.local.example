# ---------------------------------------------------------------------------
# Copy this file to .env.local and fill in your own values.
# .env.local is gitignored — never commit real keys.
# Keep THIS example file filled with placeholders only.
# ---------------------------------------------------------------------------

# Suno API (required) — https://sunoapi.org
SUNO_API_KEY="your-suno-api-key"
SUNO_API_BASE_URL="https://api.sunoapi.org"

# Public base URL of this app, used to build the Suno callback URL.
# Optional in local dev (falls back to the request origin); set it in production.
NEXT_PUBLIC_BASE_URL="https://your-app.vercel.app"

# Callback authentication and per-task access credentials (required in production).
# Generate independent high-entropy values, for example with a password manager.
SUNO_CALLBACK_TOKEN="replace-with-a-long-random-callback-token"
TASK_ACCESS_SECRET="replace-with-a-long-random-task-access-secret"

# Only these HTTPS hosts may be downloaded into private Blob storage. Comma-separated.
# Set this to the exact media hostnames returned by your Suno provider.
SUNO_MEDIA_ALLOWED_HOSTS="media.example-suno-provider.com"

# Shared generation quota per IP (or visitor id when IP is unavailable).
GENERATE_RATE_LIMIT="5"
GENERATE_RATE_WINDOW_SECONDS="3600"

# Admin token that gates /admin/usage and /api/admin/* (required in production).
ADMIN_USAGE_TOKEN="use-a-long-random-admin-token"

# Usage-monitoring storage (optional).
# Without these, events are written locally to .data/usage-events.jsonl.
# For Vercel, create the table with supabase-usage-events.sql, then set:
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_USAGE_TABLE="usage_events"

# Vercel Blob storage (optional) — https://vercel.com/docs/storage/vercel-blob
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_your-token"
